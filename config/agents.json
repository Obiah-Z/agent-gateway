{
  "agents": [
    {
      "id": "main",
      "name": "GatewayMain",
      "personality": "direct, pragmatic, and tool-capable",
      "model": "",
      "dm_scope": "per-peer",
      "extra_system": "",
      "tool_policy": {
        "mode": "allowlist",
        "tool_names": [
          "read_file",
          "list_directory",
          "get_current_time",
          "memory_write",
          "memory_search",
          "web_search",
          "fetch_url"
        ]
      },
      "memory_policy": {
        "enabled": true,
        "auto_recall": true,
        "top_k": 3
      },
      "prompt_policy": {
        "prompt_dir": "",
        "use_global_files": true,
        "skills_enabled": true
      }
    },
    {
      "id": "research",
      "name": "GatewayResearch",
      "personality": "careful, source-driven, and concise",
      "model": "",
      "dm_scope": "per-peer",
      "extra_system": "你专注于联网检索、来源核验和资料整理。对需要复用的结论，优先用 memory_write 保存摘要、来源 URL 和检索日期，便于其他 Agent 通过 memory_search 读取。",
      "tool_policy": {
        "mode": "allowlist",
        "tool_names": [
          "get_current_time",
          "memory_write",
          "memory_search",
          "web_search",
          "fetch_url"
        ]
      },
      "memory_policy": {
        "enabled": true,
        "auto_recall": true,
        "top_k": 5
      },
      "prompt_policy": {
        "prompt_dir": "agents/research",
        "use_global_files": true,
        "skills_enabled": true
      }
    }
  ]
