# Copy to /etc/agent-gateway/agent-gateway.env and fill real secrets.

ANTHROPIC_API_KEY=replace-me
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
MODEL_ID=deepseek-v4-pro

GATEWAY_RUNTIME_ROLES=all
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8765
GATEWAY_DASHBOARD_ENABLED=true
GATEWAY_DASHBOARD_HOST=127.0.0.1
GATEWAY_DASHBOARD_PORT=8780
FEISHU_WEBHOOK_HOST=127.0.0.1
FEISHU_WEBHOOK_PORT=8766
FEISHU_WEBHOOK_PATH=/webhooks/feishu

GATEWAY_WORKSPACE_ROOT=/home/obiah/Desktop/claw0/gateway/workspace
GATEWAY_DATA_DIR=/home/obiah/Desktop/claw0/gateway/data
GATEWAY_CONFIG_DIR=/home/obiah/Desktop/claw0/gateway/config

GATEWAY_REDIS_ENABLED=true
GATEWAY_REDIS_URL=redis://127.0.0.1:6379/0
GATEWAY_REDIS_SOCKET_TIMEOUT_SECONDS=1.0

GATEWAY_POSTGRES_ENABLED=true
GATEWAY_POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres
GATEWAY_POSTGRES_CONNECT_TIMEOUT_SECONDS=2.0

GATEWAY_DELIVERY_BROKER=rabbitmq
GATEWAY_RABBITMQ_URL=amqp://admin:admin123@127.0.0.1:5672/
GATEWAY_RABBITMQ_EXCHANGE=agent_gateway.delivery
GATEWAY_RABBITMQ_QUEUE=agent_gateway.delivery.outbound
GATEWAY_RABBITMQ_DEAD_LETTER_EXCHANGE=agent_gateway.delivery.dlx
GATEWAY_RABBITMQ_DEAD_LETTER_QUEUE=agent_gateway.delivery.dead
GATEWAY_RABBITMQ_CONNECT_TIMEOUT_SECONDS=2.0

GATEWAY_INBOUND_TASK_QUEUE_ENABLED=false
GATEWAY_INBOUND_BROKER=none
GATEWAY_INBOUND_SESSION_LOCK_TTL_SECONDS=300
GATEWAY_INBOUND_SESSION_LOCK_RENEW_INTERVAL_SECONDS=0
GATEWAY_TASK_WORKER_ID=systemd-worker-1
GATEWAY_TASK_WORKER_CONCURRENCY=2

GATEWAY_WEB_SEARCH_ENABLED=false
GATEWAY_WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_BOT_OPEN_ID=

TELEGRAM_BOT_TOKEN=
