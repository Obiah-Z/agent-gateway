# 模型与 Anthropic 兼容接口
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
MODEL_ID=deepseek-v4-pro

# 网关监听、目录与默认 Agent
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8765
GATEWAY_WORKSPACE_ROOT=./workspace
GATEWAY_DATA_DIR=./data
GATEWAY_CONFIG_DIR=./config
GATEWAY_DEFAULT_AGENT_ID=main
GATEWAY_DEFAULT_AGENT_NAME=GatewayMain

# Agent Loop、工具执行与上下文保护
GATEWAY_MAX_ITERATIONS=12
GATEWAY_MAX_TOKENS=4096
GATEWAY_TOOL_TIMEOUT_SECONDS=30
GATEWAY_MAX_TOOL_OUTPUT_CHARS=50000
GATEWAY_CONTEXT_SAFE_LIMIT=180000
GATEWAY_MAX_OVERFLOW_COMPACTION=3
GATEWAY_FALLBACK_MODELS=

# 入站并发控制：限制同时运行的入站 lane 数，避免多通道并发过高打爆模型或工具资源
GATEWAY_INBOUND_MAX_CONCURRENT_LANES=4
# 入站背压控制：限制全局入口队列和单个 lane 的最大积压，超过后拒绝新消息并提示稍后重试
GATEWAY_INBOUND_MAX_QUEUE_SIZE=200
GATEWAY_INBOUND_MAX_LANE_QUEUE_SIZE=20
# 长任务提示：单条入站消息超过该秒数仍未完成时，先推送“继续处理中”提示；设为 0 可关闭
GATEWAY_INBOUND_LONG_TASK_NOTICE_SECONDS=15

# Web Search 工具
GATEWAY_WEB_SEARCH_ENABLED=false
GATEWAY_WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
GATEWAY_WEB_SEARCH_TIMEOUT_SECONDS=15
GATEWAY_WEB_SEARCH_MAX_RESULTS=5
GATEWAY_WEB_SEARCH_MAX_OUTPUT_CHARS=12000

# 运行事件：按日期写入 data/events/runtime-events-YYYY-MM-DD.jsonl，并清理过期文件
GATEWAY_EVENTS_RETENTION_DAYS=14
GATEWAY_METRICS_RETENTION_DAYS=14
GATEWAY_METRICS_INTERVAL_SECONDS=60

# Telegram 通道
TELEGRAM_BOT_TOKEN=

# 飞书主账号与 Webhook
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_BOT_OPEN_ID=
FEISHU_RENDER_MODE=auto
FEISHU_CARD_PAGE_MAX_BYTES=6000
FEISHU_TEXT_PAGE_MAX_BYTES=12000
FEISHU_ENABLE_STATEFUL_CARDS=false
FEISHU_WEBHOOK_HOST=127.0.0.1
FEISHU_WEBHOOK_PORT=8766
FEISHU_WEBHOOK_PATH=/webhooks/feishu
FEISHU_SIGNATURE_WINDOW_SECONDS=300
FEISHU_EVENT_DEDUP_TTL_SECONDS=86400

# 飞书长连接简易接入
# 这一部分是“扫码后直接打开飞书机器人”的最小配置。
# 你仍然需要先运行 `lark-cli config init` 完成本机飞书应用登录/绑定。
# 网关本身不要求在这里填写飞书 app_secret，但需要一个可打开机器人会话的链接。
FEISHU_ONBOARDING_BOT_LINK=
FEISHU_ONBOARDING_AUTO_BIND_FIRST_MESSAGE=true
FEISHU_ONBOARDING_AUTO_BIND_BOT_ADDED=false

# 长连接消费者配置
# lark-cli 会从自己的本地配置读取飞书应用信息，网关只负责消费事件和发送回复。
# event_keys 支持逗号分隔或数组形式；建议至少包含消息事件和机器人被加群事件。

# 运维监控台：默认只监听本机，页面通过 WebSocket 控制面读取运行状态
GATEWAY_DASHBOARD_ENABLED=true
GATEWAY_DASHBOARD_HOST=127.0.0.1
GATEWAY_DASHBOARD_PORT=8780
GATEWAY_DASHBOARD_REFRESH_INTERVAL_SECONDS=15

# 飞书第二账号占位：启用前需要填入新飞书应用的真实配置，并把 config/channels.json 中 feishu-secondary.enabled 改为 true
FEISHU_SECONDARY_APP_ID=
FEISHU_SECONDARY_APP_SECRET=
FEISHU_SECONDARY_VERIFICATION_TOKEN=
FEISHU_SECONDARY_ENCRYPT_KEY=
FEISHU_SECONDARY_BOT_OPEN_ID=
FEISHU_SECONDARY_RENDER_MODE=auto
FEISHU_SECONDARY_CARD_PAGE_MAX_BYTES=6000
FEISHU_SECONDARY_TEXT_PAGE_MAX_BYTES=12000
FEISHU_SECONDARY_ENABLE_STATEFUL_CARDS=false

# 主动任务：Heartbeat 与 Cron 默认投递目标
HEARTBEAT_INTERVAL_SECONDS=1800
HEARTBEAT_ACTIVE_START=9
HEARTBEAT_ACTIVE_END=22
GATEWAY_PROACTIVE_CHANNEL=cli
GATEWAY_PROACTIVE_ACCOUNT_ID=cli-local
GATEWAY_PROACTIVE_PEER_ID=cli-user
GATEWAY_PROACTIVE_AGENT_ID=main

# 告警通知：为空则只在本地记录告警历史，不主动发送通知
GATEWAY_ALERT_CHANNEL=
GATEWAY_ALERT_ACCOUNT_ID=
GATEWAY_ALERT_PEER_ID=
GATEWAY_ALERT_AGENT_ID=main
GATEWAY_ALERTS_RETENTION_DAYS=14
GATEWAY_ALERTS_INTERVAL_SECONDS=60
