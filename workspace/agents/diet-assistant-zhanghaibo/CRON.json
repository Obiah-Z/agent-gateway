{
  "jobs": [
    {
      "id": "daily-diet-plan",
      "name": "每日饮食计划",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "0 6 * * *",
        "tz": "Asia/Shanghai"
      },
      "target": {
        "channel": "wework",
        "account_id": "wework-main",
        "peer_id": "ZhangHaiBo",
        "agent_id": "diet-assistant-zhanghaibo"
      },
      "payload": {
        "kind": "diet_plan_generate",
        "user_scope": "user:wework:wework-main:direct:zhanghaibo",
        "date": "today"
      },
      "delete_after_run": false
    },
    {
      "id": "daily-nutrition-summary",
      "name": "晚间热量汇总",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "0 22 * * *",
        "tz": "Asia/Shanghai"
