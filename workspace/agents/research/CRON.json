{
  "jobs": [
    {
      "id": "agent-news-digest",
      "name": "AI Agent 每日简报",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "30 9 * * *",
        "tz": "Asia/Shanghai"
      },
      "payload": {
        "kind": "agent_news_digest",
        "sources_file": "agent-news-sources.json",
        "lookback_hours": 24,
        "max_items": 6,
        "per_source_max_items": 3,
        "skip_if_empty": true,
        "timeout_seconds": 12
      },
      "delete_after_run": false
    }
  ]
}
