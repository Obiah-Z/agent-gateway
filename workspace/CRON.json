{
  "jobs": [
    {
      "id": "morning-briefing",
      "name": "早间简报",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "0 9 * * *",
        "tz": "Asia/Shanghai"
      },
      "payload": {
        "kind": "agent_turn",
        "message": "检查今天的日程、天气以及待处理提醒，并输出一段简短的早间摘要。"
      },
      "delete_after_run": false
    },
    {
      "id": "health-check",
      "name": "系统健康检查",
      "enabled": true,
      "schedule": {
        "kind": "every",
        "every_seconds": 3600,
        "anchor": "2026-02-24T00:00:00+08:00"
      },
      "payload": {
        "kind": "agent_turn",
        "message": "检查系统健康状态，包括内存占用、磁盘空间和运行中的服务。只有在确实需要处理时才输出报告。"
      },
      "delete_after_run": false
    }
  ]
}
