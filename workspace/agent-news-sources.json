{
  "sources": [
    {
      "id": "openai-news",
      "type": "rss",
      "enabled": true,
      "url": "https://openai.com/news/rss.xml",
      "max_results": 5,
      "tags": ["official", "openai", "model", "agent"]
    },
    {
      "id": "anthropic-news",
      "type": "html_page",
      "enabled": true,
      "url": "https://www.anthropic.com/news",
      "url_patterns": ["/news/"],
      "exclude_url_patterns": ["/company/", "/careers", "/legal"],
      "max_results": 5,
      "tags": ["official", "anthropic", "model", "agent"]
    },
    {
